# Copy this file to docker-compose.override.yml and uncomment the options you need.
# Docker Compose automatically merges it with docker-compose.yml.
# This file is gitignored, so your settings won't conflict with git pull.

services:

  ## Store every individual knock in SQLite (uses ~600 MB/year)
  ## Use --save-knocks for all protocols, or --save-knocks=SIP,SMTP for selective
  # honeypot-monitor:
  #   command: python -u monitor.py --save-knocks

  ## Auto-add IPs to blocklist.txt after N total hits (disabled by default)
  ## Note: counts all-time hits, so existing high-hit IPs will be blocked on their next knock
  # honeypot-monitor:
  #   command: python -u monitor.py --max-knocks 5000

  ## Select which honeypots to run (default: all)
  ## Protocols: SSH, TNET, FTP, RDP, SMB, SIP, SMTP, MAIL
  # honeypot-monitor:
  #   environment:
  #     - ENABLED_PROTOCOLS=SSH
  #     # or: ENABLED_PROTOCOLS=SSH,TNET,SMTP

  ## HTTPS — uncomment the block below, then place certs in certs/
  # web:
  #   environment:
  #     - ENABLE_SSL=true
  #   ports:
  #     - "443:443"
  #   volumes:
  #     - ./certs:/app/certs:ro

  ## Log dashboard visitors to visitors.db
  # web:
  #   environment:
  #     - LOG_VISITORS=true
