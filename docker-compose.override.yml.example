# Copy this file to docker-compose.override.yml and uncomment the options you need.
# Docker Compose automatically merges it with docker-compose.yml.
# This file is gitignored, so your settings won't conflict with git pull.

services:

  ## Store every individual knock in SQLite (uses ~600 MB/year)
  ## Use --save-knocks for all protocols, or --save-knocks=SIP,SMTP for selective
  # honeypot-monitor:
  #   command: python -u monitor.py --save-knocks

  ## Auto-add IPs to blocklist.txt after N total hits (disabled by default)
  ## Note: counts all-time hits, so existing high-hit IPs will be blocked on their next knock
  # honeypot-monitor:
  #   command: python -u monitor.py --max-knocks 5000
  ## Per-protocol: --max-knocks RDP:500  or  --max-knocks 5000,RDP:500,SIP:NONE

  ## Override SMTP banner hostname (default: reverse DNS of server IP)
  # honeypot-monitor:
  #   environment:
  #     - SMTP_HOSTNAME=mail.local

  ## Log each knock to stdout/journal (default: off — keeps journal small)
  # honeypot-monitor:
  #   environment:
  #     - TRACE_KNOCK=true

  ## Select which honeypots to run (default: all)
  ## Protocols: SSH, TNET, FTP, RDP, SMB, SIP, SMTP, HTTP
  ## Use PROTO:PORT syntax to run the same protocol on multiple ports
  # honeypot-monitor:
  #   environment:
  #     - ENABLED_PROTOCOLS=SSH
  #     # or: ENABLED_PROTOCOLS=SSH,TNET,SMTP:25,SMTP:587,HTTP:80,HTTP:443

  ## Override the web UI port (default: 8080)
  ## Set up a Cloudflare Origin Rule to forward port 80/443 → this port
  # web:
  #   environment:
  #     - WEB_PORT=9090
  #   ports:
  #     - "9090:9090"

  ## HTTPS — uncomment the block below, then place certs in certs/
  ## Place cert.pem and key.pem in certs/ (e.g. Let's Encrypt or Cloudflare Origin CA)
  # web:
  #   environment:
  #     - ENABLE_SSL=true
  #   volumes:
  #     - ./certs:/app/certs:ro

  ## Log dashboard visitors to visitors.db
  # web:
  #   environment:
  #     - LOG_VISITORS=true

  ## Federation — feeder mode: forward knocks to an aggregator server
  ## SOURCE_ID defaults to hostname; keep it short (e.g. ams2, lon1, ny)
  ## Only set AGGREGATOR_HOST to enable forwarding; local honeypots still run normally
  # honeypot-monitor:
  #   environment:
  #     - SOURCE_ID=ams2
  #     - AGGREGATOR_HOST=aggregator.example.com
  #     - AGGREGATOR_PORT=9999      # default

  ## Federation — aggregator mode: receive forwarded knocks from feeder servers
  ## Open INGEST_PORT in your firewall to feeder IPs only (no auth token — firewall is the gate)
  ## Source badges and SOURCES section appear in the UI automatically when INGEST_PORT is set
  # honeypot-monitor:
  #   environment:
  #     - INGEST_PORT=9999
  #   ports:
  #     - "9999:9999"
