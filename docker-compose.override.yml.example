# Copy this file to docker-compose.override.yml and uncomment the options you need.
# Docker Compose automatically merges it with docker-compose.yml.
# This file is gitignored, so your settings won't conflict with git pull.
#
# Most configuration (ENABLED_PROTOCOLS, SAVE_KNOCKS, MAX_KNOCKS, etc.) goes in .env —
# Docker Compose picks it up automatically. This file is only needed for things
# that can't be set via environment variables: port bindings and volumes.

services:

  ## Remove honeypot ports you don't want exposed.
  ## Must match ENABLED_PROTOCOLS in .env — Docker binds ports independently of
  ## which honeypots are actually running, so unused ports should be removed here too.
  honeypot-monitor:
    ports:
      - "21:21"     # FTP
      - "22:22"     # SSH
      - "23:23"     # Telnet
      - "25:25"     # SMTP
      - "80:80"     # HTTP
      - "443:443"   # HTTP (HTTPS scanning)
      - "587:587"   # SMTP submission
      - "3389:3389" # RDP
      - "445:445"   # SMB
      - "5060:5060" # SIP (TCP)
      - "5060:5060/udp" # SIP (UDP)

  ## Override the web UI port (default: 8080). Also set WEB_PORT=9090 in .env.
  ## The port must match in both places — the env var controls uvicorn,
  ## the ports entry controls Docker's host binding.
  # web:
  #   ports:
  #     - "9090:9090"

  ## HTTPS — place cert.pem and key.pem in certs/, set ENABLE_SSL=true in .env
  # web:
  #   volumes:
  #     - ./certs:/app/certs:ro

  ## Federation — aggregator mode: open ingest port. Also set INGEST_PORT=9999 in .env.
  # honeypot-monitor:
  #   ports:
  #     - "9999:9999"
