#!/usr/bin/env python3
"""Print Telnyx outbound rates for E.164 numbers."""

import json
import re
import sys

import telnyx_rates


def main(argv=None):
    argv = list(sys.argv[1:] if argv is None else argv)
    json_output = False
    if "--json" in argv:
        json_output = True
        argv.remove("--json")
    if not argv:
        print("usage: telnyx_rate [--json] +E164 [+E164 ...]", file=sys.stderr)
        return 2
    numbers = [arg.strip() for arg in argv]
    for number in numbers:
        if not re.fullmatch(r"\+[1-9][0-9]{1,14}", number):
            print(f"error: expected E.164 number with leading '+': {number}", file=sys.stderr)
            return 2

    try:
        results = telnyx_rates.lookup_many(numbers)
    except FileNotFoundError as e:
        print(f"error: {e}", file=sys.stderr)
        return 1

    if json_output:
        print(json.dumps(results, sort_keys=True))
    else:
        for result in results:
            rate = result.get("rate_per_minute")
            print("" if rate is None else f"{rate:g}")
    return 1 if any(not result.get("matched") for result in results) else 0


if __name__ == "__main__":
    sys.exit(main())
