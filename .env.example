# Knock-Knock configuration
# Copy this file to .env and fill in your values.
# Loaded automatically by systemd unit files and docker compose.
# Lines starting with # are comments and are ignored.

# =============================================================================
# MaxMind GeoIP (Docker only — required)
# Systemd installs geoipupdate natively; configure in /etc/GeoIP.conf instead.
# Register free at https://www.maxmind.com/en/geolite2/signup
# =============================================================================
MAXMIND_ACCOUNT_ID=your_account_id
MAXMIND_LICENSE_KEY=your_license_key

# =============================================================================
# Docker networking (Linux) — host (default) vs bridge
# =============================================================================
# Host networking (the line below, active by default): honeypots see the real attacker
# source IP (incl. UDP/SIP), self-redaction discovers the public IP automatically, and
# there is no port list to maintain — ENABLED_PROTOCOLS + the per-protocol *_PORT vars
# govern which host ports get bound. Every enabled honeypot binds the host port directly,
# so move real sshd off :22 first (see INSTALL.md).
#
# Comment this line out to use the bridge-networking docker-compose.yml instead. Bridge
# is REQUIRED on Docker Desktop / macOS / Windows (host networking is Linux-only there),
# and needs docker-compose.override.yml to publish the honeypot ports.
COMPOSE_FILE=docker-compose.host.yml

# =============================================================================
# Typical Setup
# =============================================================================
# Short name for this server shown in the dashboard (default: hostname)
# SOURCE_ID=ny

# Port the web UI listens on (default: 8080)
# WEB_PORT=8080

# HTTPS — place certs in certs/cert.pem and certs/key.pem, then enable:
# ENABLE_SSL=true
# KNOCK_KEYFILE=certs/key.pem       # override default cert path
# KNOCK_CERTFILE=certs/cert.pem     # override default cert path

# Save individual knock records to SQLite (default: off)
# Can result in large databases depending on traffic and protocols chosen.
# true or 1 = all protocols; comma-separated = selective
# SAVE_KNOCKS=true
# SAVE_KNOCKS=SIP,SMTP

# Auto-ban IPs after N total knocks (optional)
# Global limit, per-protocol, or mixed (NONE = disable for a protocol)
# MAX_KNOCKS=5000
# MAX_KNOCKS=5000,RDP:1000,SIP:NONE

# Auto-ban duration in days (default: 30; 0 = permanent)
# BAN_DURATION=30

# =============================================================================
# Federation — feeder mode (forward knocks to a central aggregator)
# Set AGGREGATOR_HOST to enable; local honeypots still run normally
# =============================================================================
# AGGREGATOR_HOST=aggregator.example.com
# AGGREGATOR_PORT=9999

# =============================================================================
# Federation — aggregator mode (receive knocks from feeder servers)
# Open INGEST_PORT in your firewall to feeder IPs only
# =============================================================================
# INGEST_PORT=9999

# =============================================================================
# Advanced
# =============================================================================
# Run only specific honeypots (default: all)
# Protocols: SSH, TNET, FTP, RDP, SMB, SIP, HTTP, SMTP
# Use PROTO:PORT syntax to run on multiple ports, e.g. HTTP:80,HTTP:443
# ENABLED_PROTOCOLS=SSH,TNET,FTP,RDP,SMB,SIP,HTTP,SMTP

# Number of uvicorn worker processes (systemd only; Docker uses 2 via CLI)
# WEB_WORKERS=2

# Redact your own server's IP from knock output (self-protection)
# REDACT_SELF_IPS=1.2.3.4
# REDACT_SELF_HOSTS=your-hostname.example.com
# REDACT_SELF_DOMAINS=example.com

# Redis connection (advanced)
# REDIS_HOST=localhost   # set to 'redis' in Docker
# REDIS_DB=0

# Hide specific dashboard panels (e.g. for work/corporate deployments)
# Comma-separated list of panel names: FEED, GLOBE, LOC, USER, PASS, ISP, IP, LAST, STATS, TRIVIA, JOKES, ABOUT
# EXCLUDE_PANELS=JOKES,TRIVIA

# =============================================================================
# Debugging & Logging
# =============================================================================
# Log each knock to stdout/journal
# TRACE_KNOCK=true

# Log dashboard visitors to data/visitors.db
# LOG_VISITORS=true

# Log unhandled HTTP 404s to the web server log
# LOG_UNHANDLED_HTTP=true

# =============================================================================
# Honeypot-Specific Controls
# =============================================================================

# --- SMTP ---
# Override SMTP banner hostname (default: reverse DNS of server IP)
# SMTP_HOSTNAME=mail.example.com
# MTA fingerprint to emulate: postfix, exim, sendmail, exchange
# SMTP_FINGERPRINT=postfix
# SMTP_TRACE=true
# SMTP_TRACE_IP=1.2.3.4

# --- SMB ---
# Save files uploaded by attackers to a quarantine directory
# SMB_QUARANTINE_DIR=/tmp/quarantine
# SMB_TRACE=true
# SMB_TRACE_IP=1.2.3.4

# --- SIP ---
# Which dialed forms the fake PBX answers (200) vs rejects (404).
# all | none | comma list of dial-out prefixes prepended to the bare E.164 digits
# (bare = no prefix, plus +, 00, 011, 9, ...). Knocks are recorded regardless.
# SIP_OK_DIALPLAN=+,bare,00,011,9
# SIP_TRACE=true
# SIP_TRACE_IP=1.2.3.4

# --- Modbus TCP (MODB) ---
# Device identity returned to Read Device Identification / Report Server ID
# MODB_VENDOR=Schneider Electric
# MODB_PRODUCT_CODE=BMX P34 2020
# MODB_REVISION=V2.60
# MODB_VENDOR_URL=www.schneider-electric.com
# MODB_PRODUCT_NAME=Modicon M340
# MODB_MODEL_NAME=BMX P34 2020
# MODB_SERVERID=text:Modicon_M340
# MODB_SERVERID=hex:01 ff 4d 6f 64 69 63 6f 6e 5f 4d 33 34 30
# MODB_TRACE=true
# MODB_TRACE_IP=1.2.3.4

# --- HTTP ---
# HTTP_TRACE=true
# HTTP_TRACE_IP=1.2.3.4

# --- RDP ---
# Also capture classic RDP (non-NLA) credentials
# RDP_CLASSIC_CAPTURE=false
# RDP_TRACE=true
# RDP_TRACE_IP=1.2.3.4

# --- SSH ---
# Banner/fingerprint profile to emulate
# SSH_PROFILE=openssh_8_9_ubuntu
# SSH_TRACE=true
# SSH_TRACE_IP=1.2.3.4
